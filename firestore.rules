rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own data
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // DECISION(v1.19.404): Supplier quotes — restricted to authenticated users who own the quote
    // or are members of the company that created it. Previously allowed any authenticated user.
    match /supplierQuotes/{quoteId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        (resource.data.companyId != null &&
         exists(/databases/$(database)/documents/companies/$(resource.data.companyId)/members/$(request.auth.uid)))
      );
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        (resource.data.companyId != null &&
         exists(/databases/$(database)/documents/companies/$(resource.data.companyId)/members/$(request.auth.uid)))
      );
    }

    // DECISION(v1.19.404): BC price update audit log — restricted to owner or company members.
    match /bcPriceUpdates/{updateId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        !('companyId' in request.resource.data) ||
        request.resource.data.companyId == null ||
        exists(/databases/$(database)/documents/companies/$(request.resource.data.companyId)/members/$(request.auth.uid))
      );
    }

    // DECISION(v1.19.404): Supplier RFQ upload tokens — token-based access for supplier portal.
    // Read: public (suppliers access via token link). Write: authenticated users only + size guard.
    match /rfqUploads/{token} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if true;
      allow delete: if request.auth != null;
    }

    // Company data
    match /companies/{companyId} {
      function isMember() {
        return request.auth != null &&
               exists(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid));
      }
      function memberRole() {
        return get(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid)).data.role;
      }
      function isAdminMember() {
        return isMember() && memberRole() == 'admin';
      }
      function canWrite() {
        return isMember() && memberRole() != 'view';
      }

      allow read: if isMember();
      // Existing admins can update/delete; any authenticated user can create a new company they own
      allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isAdminMember();

      match /members/{memberId} {
        allow read: if isMember();
        // Self-add: company creation flow, or accepting an invite
        allow create: if request.auth != null && memberId == request.auth.uid;
        // Admin can change roles and remove other members (not self)
        allow update: if isAdminMember() && memberId != request.auth.uid;
        allow delete: if isAdminMember() && memberId != request.auth.uid;
      }

      match /pendingInvites/{token} {
        // Members can see invite list; invitee can read their own invite to accept it
        allow read: if isMember() ||
                    (request.auth != null && resource.data.email == request.auth.token.email);
        // Admin can create and cancel invites
        allow create: if isAdminMember();
        allow delete: if isAdminMember() ||
                      (request.auth != null && resource.data.email == request.auth.token.email);
        allow update: if false;
      }

      match /projects/{projectId} {
        allow read: if isMember();
        allow write: if canWrite();
      }

      match /config/{configId} {
        allow read: if isMember();
        allow write: if isAdminMember();
      }
    }
  }
}
