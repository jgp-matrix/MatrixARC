rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // DECISION(v1.19.529): Allow all authenticated users to read AND write page images.
    // Team members need to upload updated drawings to each other's projects.
    match /pageImages/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    // DECISION(v1.19.959): Original-PDF retention for bulletproof BOM extraction.
    // Same access pattern as pageImages — team members need to access each other's
    // retained PDFs for AI re-extraction. Used by extractBomPage native PDF path.
    // Size cap prevents accidentally storing absurdly large files (Anthropic max is
    // 32 MB per document anyway).
    match /originalPdfs/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 32 * 1024 * 1024;
    }
    // DECISION(v1.19.404 → v1.19.963): Supplier uploads — token-based, kept open for
    // supplier portal flow. Restrict file size to 25MB AND content type to PDF only
    // to prevent suppliers from using the bucket as a generic file host (security audit
    // L-3). The supplier portal client UI already enforces PDF-only via file picker,
    // but the storage rule was bypassable via direct API write. PDF check uses the
    // contentType validator on the upload request.
    match /supplierUploads/{token}/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 25 * 1024 * 1024
                   && request.resource.contentType == "application/pdf";
    }
    match /supplierQuotePDFs/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // DECISION(v1.19.404): Company storage — verify user is a member of the company.
    // Previously allowed any authenticated user to read/write any company's files.
    match /companies/{companyId}/{allPaths=**} {
      allow read, write: if request.auth != null &&
        firestore.exists(/databases/(default)/documents/companies/$(companyId)/members/$(request.auth.uid));
    }
  }
}
